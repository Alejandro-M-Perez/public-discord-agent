Important:
- This config is a starting point, not the full security implementation.
- The application layer must prevent untrusted users from ever using the hosted model.
- Do not rely on provider fallbacks for access control.
- Keep the hosted provider configured for trusted use, while the router enforces that public traffic stays local-only.
- Phase-1 should block any disallowed channel or non-owner DM before model selection.
- If the local public model is unavailable, refuse the request instead of falling back to hosted.

{
  "gateway": {
    "mode": "local"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-trusted",
        "fallbacks": [
          "lmstudio/local-public"
        ]
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "openai": {
        "apiKey": "${OPENAI_API_KEY}"
      },
      "lmstudio": {
        "baseUrl": "http://127.0.0.1:1234/v1",
        "apiKey": "lmstudio",
        "api": "openai-responses",
        "models": [
          {
            "id": "local-public",
            "name": "Local Public Model",
            "reasoning": false,
            "input": ["text"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 32768,
            "maxTokens": 512
          }
        ]
      }
    }
  }
}
